# Variáveis de ambiente para rodar o projeto

# ============================================
# Backend
# ============================================

NODE_ENV=development # Ambiente da aplicação: 'development' ou 'production'
PORT=3333 # Porta em que o servidor backend escuta
DATABASE_URL=postgresql://user:password@localhost:5432/dbname # URL de conexão com PostgreSQL (PostgreSQL)

# Autenticação JWT
JWT_SECRET=seu_segredo_jwt # Segredo para assinatura de tokens JWT
JWT_EXPIRES_IN=1d # Tempo de expiração do token JWT (ex: 1d, 12h, 7d)

# Redis
REDIS_URL=redis://localhost # URL do Redis
REDIS_PORT=6379 # Porta do Redis
REDIS_PASSWORD=senha_redis # Senha do Redis (se houver)

# CORS - Permite requisições de outras origens
CORS_ORIGINS=http://localhost:5173 # Origens permitidas (separadas por vírgula)

# Upload de arquivos
UPLOAD_DIR=uploads # Diretório de upload de arquivos
MAX_FILE_SIZE=5242880 # Tamanho máximo de upload em bytes (ex: 5MB = 5242880)

# OpenSearch - Motor de busca
OPENSEARCH_URL=http://localhost:9200 # URL do OpenSearch

# Swagger/API Docs
SWAGGER_USER=admin # Usuário para autenticação Swagger (se usar)
SWAGGER_PASSWORD=admin # Senha para autenticação Swagger (se usar)

# Logs
LOG_LEVEL=info # Nível de log (info, debug, warn, error)

# ============================================
# Frontend
# ============================================

VITE_API_URL=http://localhost:3333/api # URL da API backend (Vite React)
VITE_WS_URL=ws://localhost:3333 # URL de WebSocket (Vite React)
VITE_APP_NAME=MeuApp # Nome do aplicativo para exibir no frontend
