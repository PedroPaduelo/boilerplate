# =============================================================================
# .env — Docker Compose / EasyPanel
# =============================================================================
# Copie este arquivo para .env e ajuste os valores.
# Gere JWT_SECRET e CONNECTION_ENC_KEY com:
#   openssl rand -base64 32
# =============================================================================

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=boilerplate
POSTGRES_PORT=5432

# Quando o Postgres roda no próprio compose, a URL interna é:
DATABASE_URL=postgresql://postgres:troque-esta-senha@postgres:5432/boilerplate?schema=public
# Se usar um Postgres externo (EasyPanel DB), troque para a URL externa:
# DATABASE_URL=postgresql://postgres:sua-senha@host:5432/boilerplate?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Backend (Fastify) ---
BACKEND_PORT=4000
BACKEND_BASE_URL=http://localhost:4000
JWT_SECRET=gere-com-openssl-rand-base64-32
CONNECTION_ENC_KEY=gere-com-openssl-rand-base64-32

CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# Swagger
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# pg-runner
PG_RUNNER_STATEMENT_TIMEOUT_MS=30000
PG_RUNNER_MAX_ROWS=50000
PG_RUNNER_POOL_MAX=8
QUERY_EXEC_WORKER_CONCURRENCY=6

# MCP (opcional — vazio = endpoint /mcp desabilitado)
MCP_API_KEY=
MCP_SERVICE_USER_ID=
MCP_SERVICE_USER_EMAIL=

# Export (PDF)
EXPORT_PRINT_BASE_URL=http://frontend:5173
EXPORT_BRAND=Prefeitura

# --- Frontend (Vite/nginx) ---
FRONTEND_PORT=5173
# URL PÚBLICA do backend que o navegador do usuário vai acessar.
# Em deploy: a URL HTTPS do backend no EasyPanel.
FRONTEND_API_URL=http://localhost:4000
