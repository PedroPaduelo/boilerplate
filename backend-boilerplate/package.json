{
  "name": "backend-boilerplate",
  "version": "1.0.0",
  "description": "Backend boilerplate with Fastify, Prisma, Redis, BullMQ and Socket.IO",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup",
    "build:catalog": "tsx scripts/build-catalog.ts",
    "build:catalog:watch": "tsx scripts/build-catalog.ts --watch",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "service:up": "docker-compose up -d postgres redis",
    "service:down": "docker-compose down",
    "dev:up": "npm run service:up && npm run dev",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "prepare": "husky"
  },
  "keywords": [
    "fastify",
    "prisma",
    "redis",
    "bullmq",
    "socket.io",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@bull-board/api": "^6.14.2",
    "@bull-board/fastify": "^6.14.2",
    "@dashboards/contracts": "file:../shared/contracts",
    "@fastify/autoload": "^6.3.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.1.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@prisma/client": "^6.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.64.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pg-cursor": "^2.21.0",
    "rate-limiter-flexible": "^9.1.1",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76",
    "zod-error": "^1.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.15.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.0",
    "prisma": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
