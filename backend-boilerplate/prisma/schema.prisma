// =============================================================================
// PLATAFORMA DE DASHBOARDS/RELATÓRIOS GERADOS POR IA — schema Prisma (MVP)
//
// Decisões travadas (ver docs/plano/30-modelagem-dados.md):
//   - Mono-prefeitura: SEM tabela Organization. A prefeitura é implícita (a
//     própria instância). Visibilidade ORG = prefeitura inteira.
//   - RBAC com role GLOBAL (não escopado por departamento).
//   - SEM histórico de versões: só DRAFT + PUBLISHED nos artefatos (Chart,
//     Dashboard). Não há ChartVersion/DashboardVersion.
//   - SEM AuditLog no MVP.
//   - SEM ChatThread/ChatMessage: o agente de IA roda EXTERNO e consome nosso
//     MCP. O chat é responsabilidade da F3 (mockado) e da F2 (MCP server).
//   - Catálogo de blocos vive EM CÓDIGO (não em tabela). Só o tipo é
//     persistido como string (catalogType).
//   - Cache vive no Redis (não vira tabela).
//   - Conexões externas: SOMENTE Postgres, read-only. Credencial cifrada
//     at-rest (AES-256-GCM) no campo `passwordCipher`.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

/// RBAC global. USER = conta autenticada sem acesso a dashboards (matriz
/// detalhada em docs/plano/01-fundacao-rbac-tenancy.md).
enum UserRole {
  ADMIN
  ANALYST
  CREATOR
  VIEWER
  USER
}

/// Visibilidade aplicável a Connection/Chart/Dashboard.
enum Visibility {
  PRIVATE
  DEPARTMENT
  ORG
}

/// Status corrente do artefato (Chart/Dashboard). Sem histórico — apenas
/// indica o estado vigente. Publish copia draft → published.
enum ArtifactStatus {
  DRAFT
  PUBLISHED
}

/// Tipo da conexão externa. No MVP só Postgres (read-only).
enum ConnectionType {
  POSTGRES
}

/// Tipo de alvo de um ShareLink (token público com TTL).
enum ShareTargetType {
  DASHBOARD
  CHART
}

// =============================================================================
// RBAC & TENANCY (mono-prefeitura, role global)
// =============================================================================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  role        UserRole  @default(VIEWER)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  memberships DepartmentMembership[]
  connections Connection[]
  charts      Chart[]
  dashboards  Dashboard[]
  shareLinks  ShareLink[]

  @@map("users")
}

/// Departamento/repartição dentro da prefeitura. Plano (sem hierarquia) no MVP.
model Department {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships DepartmentMembership[]
  connections Connection[]
  charts      Chart[]
  dashboards  Dashboard[]

  @@map("departments")
}

/// Vínculo User × Department. Um usuário pode pertencer a N departamentos.
model DepartmentMembership {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@map("department_memberships")
}

// =============================================================================
// CONEXÕES (Postgres externo, read-only)
// =============================================================================

/// Cadastro de uma conexão a um banco Postgres externo. Usada pelo agente
/// (via MCP) e pelo runtime para executar queries. Credencial cifrada
/// (AES-256-GCM) em `passwordCipher`.
model Connection {
  id             String         @id @default(cuid())
  name           String
  description    String?
  type           ConnectionType @default(POSTGRES)
  host           String
  port           Int            @default(5432)
  database       String
  username       String
  passwordCipher String         @map("password_cipher")
  sslMode        String         @default("require") @map("ssl_mode")
  options        Json?
  ownerId        String         @map("owner_id")
  departmentId   String?        @map("department_id")
  visibility     Visibility     @default(DEPARTMENT)
  isActive       Boolean        @default(true) @map("is_active")
  /// unknown | ok | error — atualizado por `POST /connections/:id/test`.
  status         String         @default("unknown")
  lastTestedAt   DateTime?      @map("last_tested_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  owner      User        @relation(fields: [ownerId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@map("connections")
}

// =============================================================================
// GRÁFICO (entidade 1ª classe, reusável; DRAFT + PUBLISHED)
// =============================================================================

/// Gráfico/cartão reutilizável, referenciado por um ou mais Dashboards.
/// Catálogo de blocos vive em código; `catalogType` é o identificador do
/// bloco no registry (ex.: "kpi", "bar", "title").
///
/// Publish copia `draft*` → `published*` e seta `publishedAt`. Unpublish zera
/// os campos published. dev mode usa `draft*` (sem cache); published mode usa
/// `published*` (com cache).
model Chart {
  id           String         @id @default(cuid())
  title        String
  catalogType  String         @map("catalog_type")
  ownerId      String         @map("owner_id")
  departmentId String?        @map("department_id")
  visibility   Visibility     @default(PRIVATE)
  status       ArtifactStatus @default(DRAFT)

  /// Cópia de trabalho — sempre editável; usada em dev/sem cache.
  draftProps       Json @map("draft_props")
  /// { connectionId, query, params[], transform, ttlSeconds }
  draftDataBinding Json @map("draft_data_binding")

  /// Cópia publicada — null até o 1º publish; cacheada quando vigente.
  publishedProps       Json?     @map("published_props")
  publishedDataBinding Json?     @map("published_data_binding")
  publishedAt          DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner      User        @relation(fields: [ownerId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@map("charts")
}

// =============================================================================
// DASHBOARD (layout referencia charts; DRAFT + PUBLISHED)
// =============================================================================

/// Dashboard composto por filtros + linhas (seções) + gráficos.
/// O `publishedLayout` referencia `chartId`s (Chart.id) — reuso entre
/// dashboards é permitido.
///
/// draftLayout/publishedLayout: { filters[], rows[] } (ver contrato em
/// docs/plano/20-contrato-dashboard.md).
model Dashboard {
  id           String         @id @default(cuid())
  title        String
  ownerId      String         @map("owner_id")
  departmentId String?        @map("department_id")
  visibility   Visibility     @default(PRIVATE)
  status       ArtifactStatus @default(DRAFT)

  draftLayout     Json      @map("draft_layout")
  publishedLayout Json?     @map("published_layout")
  publishedAt     DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner      User        @relation(fields: [ownerId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@map("dashboards")
}

// =============================================================================
// SHARE LINK (TTL a partir da 1ª abertura)
// =============================================================================

/// Link público (sem auth) com TTL contado a partir da 1ª abertura.
/// `firstAccessedAt` é setado na 1ª abertura; `expiresAt` é derivado como
/// `firstAccessedAt + durationSeconds`. Revogação manual zera o ciclo via
/// `revokedAt`.
model ShareLink {
  id              String          @id @default(cuid())
  token           String          @unique
  targetType      ShareTargetType @map("target_type")
  targetId        String          @map("target_id")
  createdById     String          @map("created_by_id")
  durationSeconds Int             @map("duration_seconds")
  firstAccessedAt DateTime?       @map("first_accessed_at")
  expiresAt       DateTime?       @map("expires_at")
  revokedAt       DateTime?       @map("revoked_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  createdBy User @relation(fields: [createdById], references: [id])

  @@map("share_links")
}
