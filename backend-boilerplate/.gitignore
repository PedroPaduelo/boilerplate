# Dependencies
node_modules/

# Build
dist/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Uploads
uploads/*
!uploads/.gitkeep

# Prisma
# Note: `prisma/migrations/migration_lock.toml` is intentionally NOT ignored
# — Prisma's docs require it to be committed so the migration engine knows
# the provider. Earlier versions of this .gitignore listed
# `*_migration_lock.toml`, which never matched the real filename.

# Temp
temp/
*.tmp
