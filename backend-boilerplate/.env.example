# Application
NODE_ENV=development
PORT=4000
BASE_URL=http://localhost:4000
# URL pública do frontend (para montar links de compartilhamento de dashboards)
WEB_APP_URL=https://boilerplate-fe-cmqg5udk.cloud.serendiped.com

# JWT - IMPORTANT: Generate a secure random string (min 32 chars) for production
# Use: openssl rand -base64 32
JWT_SECRET=ChangeMe-Generate-Secure-Random-String-Min-32-Chars

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/dbname?sslmode=require

# Redis
REDIS_URL=localhost
REDIS_PASSWORD=
REDIS_PORT=6379

# Security - CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# Swagger credentials (optional - leave empty to disable auth)
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# Connections — chave de cifragem AES-256-GCM das credenciais das conexões.
# 32 bytes em base64 (gere com: openssl rand -base64 32) OU 64 chars hex.
CONNECTION_ENC_KEY=ChangeMe-Generate-With-openssl-rand-base64-32==

# pg-runner — guardrails de execução de query contra bancos externos
# Teto de tempo por query (ms). 30s dá margem p/ dashboards analíticos sobre
# tabelas grandes; queries bem escritas ficam bem abaixo disso.
PG_RUNNER_STATEMENT_TIMEOUT_MS=30000
PG_RUNNER_MAX_ROWS=50000
# Pool de conexões POR banco externo. DEVE ser >= QUERY_EXEC_WORKER_CONCURRENCY:
# cada query do worker segura 1 conexão por toda a sua duração; se houver mais
# jobs paralelos do que conexões, os excedentes morrem com
# "timeout exceeded when trying to connect" (erro client-side do pool, não do banco).
PG_RUNNER_POOL_MAX=8
PG_RUNNER_IDLE_TIMEOUT_MS=30000
# 30s: em picos de concorrência, execuções esperam a vez no pool em vez de falhar.
PG_RUNNER_CONNECT_TIMEOUT_MS=30000
# Jobs de query executados EM PARALELO pelo worker (modo published). Mantenha
# <= PG_RUNNER_POOL_MAX (o worker faz clamp defensivo, mas configure coerente).
QUERY_EXEC_WORKER_CONCURRENCY=6

# data (T-C) — cache de dados/layout (opcionais; têm defaults no código)
# TTL default (s) do cache de DADOS quando o bloco não declara ttlSeconds.
DATA_CACHE_DEFAULT_TTL=300
# TTL (s) do cache de LAYOUT publicado (dash:{id}:published) — teto de segurança;
# a invalidação real ocorre no publish/unpublish (módulo dashboards).
DATA_LAYOUT_CACHE_TTL=3600

# MCP (T-D) — servidor MCP para o agente de IA EXTERNO (POST /mcp).
# Sem MCP_API_KEY o endpoint /mcp fica DESABILITADO (503, fail-closed).
# MCP_API_KEY: token de serviço (bearer) do runtime externo (gere um aleatório forte).
MCP_API_KEY=
# Usuário em nome de quem o agente atua (âncora de RBAC/ownership). Informe o id
# OU o e-mail de um usuário existente (papel ANALYST/CREATOR recomendado).
MCP_SERVICE_USER_ID=
MCP_SERVICE_USER_EMAIL=

# export (T-J) — PDF server-side headless (Playwright/Chromium). Opcionais (defaults no código).
# Base URL do FRONTEND (onde vive a rota /print/dashboards/:id que o headless abre).
EXPORT_PRINT_BASE_URL=http://localhost:5173
# Marca exibida no cabeçalho do PDF.
EXPORT_BRAND=Prefeitura
# TTL (s) do token de SERVIÇO curto que autentica o headless na rota /print.
EXPORT_TOKEN_TTL_SECONDS=300
# Timeouts (ms) de navegação e de espera pelo marcador [data-print-ready].
EXPORT_NAV_TIMEOUT_MS=30000
EXPORT_READY_TIMEOUT_MS=30000
# TTL (s) do PDF/status guardados no Redis para download posterior.
EXPORT_RESULT_TTL_SECONDS=600

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
UPLOAD_TIMEOUT=120000

# WhatsApp via Evolution API (opcional — se as 3 NÃO estiverem setadas,
# /webhooks/evolution responde 503 e a integração fica desabilitada).
# EVOLUTION_API_URL: base URL da Evolution (ex.: http://localhost:8080).
# EVOLUTION_INSTANCE: nome da instância Evolution (case-sensitive, mesmo nome
# cadastrado na UI/manager).
# EVOLUTION_APIKEY: apikey da instância (cabeçalho `apikey`).
EVOLUTION_API_URL=
EVOLUTION_INSTANCE=
EVOLUTION_APIKEY=
# Secret opcional do webhook — se setado, /webhooks/evolution exige header
# `x-channel-secret: <valor>`. Vazio = sem gate (NÃO recomendado em prod).
CHANNELS_WEBHOOK_SECRET=
