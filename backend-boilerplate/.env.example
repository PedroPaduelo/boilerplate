# Application
NODE_ENV=development
PORT=3333
BASE_URL=http://localhost:3333

# JWT - IMPORTANT: Generate a secure random string (min 32 chars) for production
# Use: openssl rand -base64 32
JWT_SECRET=ChangeMe-Generate-Secure-Random-String-Min-32-Chars

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/dbname?sslmode=require

# Redis
REDIS_URL=localhost
REDIS_PASSWORD=
REDIS_PORT=6379

# Security - CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# Swagger credentials (optional - leave empty to disable auth)
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
UPLOAD_TIMEOUT=120000



