event: tool_step
data: {"toolName":"run_query","toolCallId":"call_function_ld5wi38z1ld1_1","args":{"connectionId":"cmqplyc2s0005ny0p11y1uqh8","sql":"SELECT n.nspname, has_schema_privilege(current_user, n.nspname, 'USAGE') AS tem_uso FROM pg_namespace n WHERE n.nspname NOT LIKE 'pg_%' AND n.nspname <> 'information_schema' ORDER BY n.nspname;"},"phase":"call"}

