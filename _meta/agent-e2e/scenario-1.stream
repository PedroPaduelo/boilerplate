data: {"messageId":"asg_1782347202426_12gnxt","delta":"Boas pistas! `RECEITA_PREVISTA_PPA` tem `PREVISTO_ANO1..ANO4` (projeção plurianual do PPA). Pode ter a LOA 2025 também. `RECEITA_ATUALIZADA` é um log de movimentações de atualização. Vou ver se RECEITA_PREVISTA_PPA tem dados para 2025:"}

event: tool_step
data: {"toolName":"run_query","toolCallId":"call_function_gn7a1ydvzpy3_1","args":{"connectionId":"cmqplyc2s0005ny0p11y1uqh8","sql":"SELECT COUNT(*) AS qtd, MIN(\"EXE\") AS min_exe, MAX(\"EXE\") AS max_exe FROM \"SCH\".\"RECEITA_PREVISTA_PPA\";"},"phase":"call"}

event: tool_step
data: {"toolName":"run_query","toolCallId":"call_function_gn7a1ydvzpy3_2","args":{"connectionId":"cmqplyc2s0005ny0p11y1uqh8","sql":"SELECT \"EXE\", COUNT(*) AS qtd, SUM(\"PREVISTO_ANO1\") AS ano1, SUM(\"PREVISTO_ANO2\") AS ano2, SUM(\"PREVISTO_ANO3\") AS ano3, SUM(\"PREVISTO_ANO4\") AS ano4 FROM \"SCH\".\"RECEITA_PREVISTA_PPA\" GROUP BY \"EXE\" ORDER BY \"EXE\" DESC LIMIT 5;"},"phase":"call"}

