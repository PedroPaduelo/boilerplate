data: {"toolName":"run_query","toolCallId":"call_function_tgojb8l6ka8b_1","args":{"connectionId":"cmqplyc2s0005ny0p11y1uqh8","sql":"SELECT a.attname AS column_name, format_type(a.atttypid, a.atttypmod) AS data_type, a.attnotnull AS not_null FROM pg_attribute a JOIN pg_class c ON c.oid = a.attrelid JOIN pg_namespace n ON n.oid = c.relnamespace WHERE n.nspname = 'SCH' AND c.relname = 'RECEITAS_PREVISAO' AND a.attnum > 0 AND NOT a.attisdropped ORDER BY a.attnum;"},"phase":"call"}

