data: {"toolName":"run_query","toolCallId":"call_019efc2f46ec7981a983ea3a","args":{"connectionId":"cmqplyc2s0005ny0p11y1uqh8","sql":"SELECT \"CODIGO_FORMATADO\", \"NOME\", \"NIVEL\", \"TIPO\", \"VALOR_JANEIRO\" FROM \"SCH\".\"RECEITAS_PORTAL\" WHERE \"ANO\"=2025 AND (\"NOME\" ILIKE '%IPTU%' OR \"NOME\" ILIKE '%ISS%' OR \"NOME\" ILIKE '%ITBI%') ORDER BY \"NIVEL\" LIMIT 30;"},"phase":"call"}

